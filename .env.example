# ── Required API Keys ────────────────────────────────────────────────────────
# Basic RAG engine (Mistral Large LLM)
MISTRAL_API_KEY=your_mistral_api_key_here

# Multi-Document Agent, Router Engine, SubQuestion, ReAct (Google Gemma / Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Separate key for Gemma 4-31b (multi-document, subquestion, router engines)
# Using a dedicated key avoids rate-limit conflicts with Gemini 2.5 Flash
GOOGLE_API_KEY_GEMMA=your_gemma_api_key_here

# Router classification + Multimodal vision (Groq / Llama-4-scout)
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Multi-Document Agent reranking (optional)
COHERE_API_KEY=your_cohere_api_key_here

# Flask session encryption key (auto-generated if omitted)
FLASK_SECRET_KEY=your_random_secret_key_here
