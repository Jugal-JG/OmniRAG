# ── Required API Keys ────────────────────────────────────────────────────────
# Basic RAG engine (Mistral Large LLM)
MISTRAL_API_KEY=your_mistral_api_key_here

# Gemini models and Groq fallbacks
GOOGLE_API_KEY=your_google_api_key_here

# Optional model/version overrides
APP_VERSION=1.5
GOOGLE_LLM=gemini-3.1-flash-lite-preview
GEMINI_LLM=gemini-2.5-flash
GROQ_SUBQUESTION_LLM=llama-3.3-70b-versatile

# Legacy Gemma key/model, kept only if you experiment with older engine settings
GOOGLE_API_KEY_GEMMA=your_gemma_api_key_here
GOOGLE_GEMMA_LLM=gemma-4-26b-a4b-it

# Router classification + Multimodal vision (Groq / Llama-4-scout)
GROQ_API_KEY=your_groq_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Multi-Document Agent reranking (optional)
COHERE_API_KEY=your_cohere_api_key_here

# Flask session encryption key (auto-generated if omitted)
FLASK_SECRET_KEY=your_random_secret_key_here
